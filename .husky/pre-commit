#!/bin/sh
# Just Three 앱 git-flow 보호용 pre-commit 훅
#
# 차단하는 것:
#   - main 브랜치에서 직접 커밋 (모든 main 반영은 release / hotfix PR 머지 경유)
#
# 전체 규칙: .claude/rules/git-flow.md

current_branch=$(git symbolic-ref --short HEAD 2>/dev/null || echo "")

if [ "$current_branch" = "main" ]; then
    echo ""
    echo "=========================================="
    echo "  ❌ 'main' 브랜치에서 직접 커밋할 수 없습니다"
    echo "=========================================="
    echo ""
    echo "  git-flow 규칙상 main 에는 release PR / hotfix PR 의 머지 커밋만 들어갑니다."
    echo "  작업은 반드시 다른 브랜치에서 진행하세요."
    echo ""
    echo "    • 신규 기능      : 'feature/<이름>'  ← develop 에서 분기"
    echo "    • 정규 릴리즈    : 'release/vX.Y.Z'   ← '/release' 커맨드가 자동 생성"
    echo "    • 긴급 패치      : 'hotfix/vX.Y.(Z+1)' ← '/hotfix' 커맨드가 자동 생성"
    echo ""
    echo "  의도한 작업 브랜치로 이동하려면:"
    echo "    git stash                # 또는 git restore --staged ."
    echo "    git checkout <대상 브랜치>"
    echo "    git stash pop            # stash 했다면"
    echo ""
    echo "  자세한 규칙: .claude/rules/git-flow.md"
    echo ""
    exit 1
fi

exit 0
