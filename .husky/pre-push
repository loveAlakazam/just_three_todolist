#!/bin/sh
# Just Three 앱 git-flow 보호용 pre-push 훅
#
# 차단하는 것:
#   1. main / develop 브랜치 삭제
#   2. main / develop 브랜치로의 force push / non-fast-forward push
#   3. main 브랜치 직접 push (릴리즈는 /release 커맨드의 PR 머지 경유, 긴급 패치는 /hotfix)
#
# 이 훅은 로컬 안전망이다. 서버(GitHub) 측에도 동일한 보호 규칙이 걸려 있으므로
# 이중 방어 역할이다. 사람이 직접 커밋/푸시할 때도 동일하게 적용된다.
#
# 전체 규칙: .claude/rules/git-flow.md
#
# 활성화: npm install (husky prepare 가 자동으로 core.hooksPath 설정)

PROTECTED_BRANCHES="main develop"
ZERO="0000000000000000000000000000000000000000"
EXIT_CODE=0

while read -r local_ref local_sha remote_ref remote_sha; do
    # tag / refs/heads 가 아닌 ref 는 스킵
    branch="${remote_ref#refs/heads/}"
    if [ "$branch" = "$remote_ref" ]; then
        continue
    fi

    # 보호 브랜치가 아니면 스킵
    is_protected=0
    for pb in $PROTECTED_BRANCHES; do
        if [ "$branch" = "$pb" ]; then
            is_protected=1
            break
        fi
    done
    if [ "$is_protected" -eq 0 ]; then
        continue
    fi

    # 1) 삭제 차단 (local_sha == 0000..)
    if [ "$local_sha" = "$ZERO" ]; then
        echo ""
        echo "=========================================="
        echo "  ❌ '$branch' 브랜치 삭제는 금지되어 있습니다"
        echo "=========================================="
        echo ""
        echo "  git-flow 보호 규칙: main / develop 은 삭제할 수 없습니다."
        echo "  자세한 규칙: .claude/rules/git-flow.md"
        echo ""
        EXIT_CODE=1
        continue
    fi

    # 2) force / non-fast-forward 차단
    #    remote_sha == 0000.. 이면 신규 브랜치 생성이므로 제외
    if [ "$remote_sha" != "$ZERO" ]; then
        if ! git merge-base --is-ancestor "$remote_sha" "$local_sha" 2>/dev/null; then
            echo ""
            echo "=========================================="
            echo "  ❌ '$branch' 브랜치로의 non-fast-forward / force push 는 금지"
            echo "=========================================="
            echo ""
            echo "  git-flow 보호 규칙: main / develop 은 force push 불가."
            echo "  커밋 히스토리 재작성이 필요해 보이면 먼저 아래 문서를 읽으세요:"
            echo "    .claude/rules/git-flow.md  (§'잘못된 릴리즈 복구 전략')"
            echo ""
            EXIT_CODE=1
            continue
        fi
    fi

    # 3) main 직접 push 차단 (/release · /hotfix 의 PR 머지 경유만 허용)
    if [ "$branch" = "main" ]; then
        echo ""
        echo "=========================================="
        echo "  ❌ 'main' 브랜치 직접 push 는 금지되어 있습니다"
        echo "=========================================="
        echo ""
        echo "  main 에는 release PR / hotfix PR 의 'gh pr merge' 를 통해서만 반영됩니다."
        echo ""
        echo "    • 정규 릴리즈 : '/release' 커맨드 (.claude/commands/release.md)"
        echo "    • 긴급 패치  : '/hotfix' 커맨드 (.claude/commands/hotfix.md)"
        echo ""
        echo "  수동 git merge + git push origin main 은 git-flow 규칙 위반입니다."
        echo "  자세한 규칙: .claude/rules/git-flow.md"
        echo ""
        EXIT_CODE=1
        continue
    fi
done

exit $EXIT_CODE
